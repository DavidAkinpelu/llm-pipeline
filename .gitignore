# LLM Pipeline specific
# All directory patterns below are anchored to the project root with a
# leading "/" — without that, "models/" would also match
# src/llm_pipeline/models/ and silently exclude source code from the repo.

# Model checkpoints and weights
*.bin
*.safetensors
*.h5
*.pth
*.pt
*.ckpt
*.pkl
*.pickle

# Model cache directories (project root only)
/models/
/checkpoints/
/weights/
/cache/
/.cache/

# Data directories (project root only)
/data/
/datasets/
*.parquet

# Benchmark outputs
/benchmarks/results/
/torch_compile_debug/

# Logs and outputs (project root only)
/logs/
/outputs/
/results/
/experiments/
/runs/
*.log

# Temporary files (project root only)
/tmp/
/temp/
/.tmp/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# LibreOffice / Office lockfiles
.~lock.*#

# Conda environment files
environment.yml
conda-meta/

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# MLflow (project root only)
/mlruns/
/mlartifacts/

# Weights & Biases (project root only)
/wandb/

# TensorBoard logs (project root only)
/tensorboard_logs/

# Hugging Face cache
.cache/huggingface/

# Quantization checkpoint artifacts (project root only — does NOT match
# the src/llm_pipeline/quantization/ source package)
/quantized_models/
*.quantized

# LoRA adapter checkpoints (project root only — does NOT match
# the src/llm_pipeline/adapters/ source package)
/adapters/
/lora_adapters/
*.lora

# Merged models (project root only)
/merged_models/

# Performance benchmarks (project root only — does NOT match
# the src/llm_pipeline/evaluation/benchmarks/ source package)
/benchmarks/
/profiles/

# Test artifacts (project root only)
/test_outputs/
/test_results/

# Documentation builds
docs/build/
docs/_build/

